# Network stack for the AgencyPay public e-service (Singapore government agency, AWS ap-southeast-1)

resource "aws_vpc" "main" {
  cidr_block = "10.20.0.0/16"
  tags = { Name = "agencypay-vpc" }
}

# Single flat subnet — everything (ALB, app servers, database) lives here.
resource "aws_subnet" "main" {
  vpc_id                  = aws_vpc.main.id
  cidr_block              = "10.20.1.0/24"
  map_public_ip_on_launch = true
  tags = { Name = "agencypay-subnet" }
}

resource "aws_internet_gateway" "gw" {
  vpc_id = aws_vpc.main.id
}

resource "aws_route_table" "public" {
  vpc_id = aws_vpc.main.id
  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.gw.id
  }
}

resource "aws_route_table_association" "main" {
  subnet_id      = aws_subnet.main.id
  route_table_id = aws_route_table.public.id
}

# One security group shared by the ALB, the app instances, and the database.
resource "aws_security_group" "everything" {
  name   = "agencypay-sg"
  vpc_id = aws_vpc.main.id

  ingress {
    description = "web"
    from_port   = 0
    to_port     = 65535
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "ssh for the vendor team"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_db_instance" "payments" {
  identifier          = "agencypay-db"
  engine              = "postgres"
  instance_class      = "db.t3.medium"
  allocated_storage   = 100
  publicly_accessible = true
  skip_final_snapshot = false
  vpc_security_group_ids = [aws_security_group.everything.id]
  # App connects with sslmode=disable; the parameter group leaves
  # rds.force_ssl = 0 so internal traffic stays plain-TCP.
}

resource "aws_lb" "public" {
  name               = "agencypay-alb"
  internal           = false
  load_balancer_type = "application"
  subnets            = [aws_subnet.main.id]
  security_groups    = [aws_security_group.everything.id]
}

# TLS terminates on the ALB with a certificate the team generated by hand
# last year and imported. No renewal automation; no expiry alarm.
resource "aws_lb_listener" "https" {
  load_balancer_arn = aws_lb.public.arn
  port              = 443
  protocol          = "HTTPS"
  certificate_arn   = aws_acm_certificate.imported.arn
  default_action {
    type             = "forward"
    target_group_arn = aws_lb_target_group.app.arn
  }
}

resource "aws_acm_certificate" "imported" {
  private_key      = file("certs/agencypay.key")   # self-signed, created 2024-06, 3-year validity
  certificate_body = file("certs/agencypay.crt")
}

resource "aws_lb_target_group" "app" {
  name     = "agencypay-app"
  port     = 8080
  protocol = "HTTP"
  vpc_id   = aws_vpc.main.id
}

# Uploaded statements bucket — website hosting was enabled for a launch demo
# and never turned off.
resource "aws_s3_bucket" "statements" {
  bucket = "agencypay-statements"
}

resource "aws_s3_bucket_public_access_block" "statements" {
  bucket                  = aws_s3_bucket.statements.id
  block_public_acls       = false
  block_public_policy     = false
  ignore_public_acls      = false
  restrict_public_buckets = false
}

resource "aws_s3_bucket_policy" "statements_read" {
  bucket = aws_s3_bucket.statements.id
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Sid       = "PublicRead"
      Effect    = "Allow"
      Principal = "*"
      Action    = ["s3:GetObject"]
      Resource  = "arn:aws:s3:::agencypay-statements/*"
    }]
  })
}
